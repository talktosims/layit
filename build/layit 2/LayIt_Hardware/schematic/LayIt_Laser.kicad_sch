  ;; ============================================================
  ;; NET CONNECTIONS (Wiring)
  ;; ============================================================
  ;;
  ;; NOTE TO ENGINEER: This section documents the logical connections.
  ;; KiCad will show ERC errors since this is a text-based schematic
  ;; without graphical wire routing. Import into KiCad and draw wires
  ;; according to this connection list:
  ;;
  ;; === POWER NETS ===
  ;; +12V:  J1.pin1 → D1.A → F1.1 → F1.2 → +12V_RAIL
  ;; +12V_RAIL: C1.+, C2.1, U1.IN, U5.V+, J3.1, J4.5, R9.1
  ;; GND:   J1.pin2 → GND_RAIL (all GND pins)
  ;; +5V:   U1.OUT → C3.+, C4.1, U4.VDD, C10.1
  ;; +3V3:  U2.OUT → C5.+, C6.1, U3.3V3, C7.1, C8.1, J5.3V3,
  ;;         R1.1, R2.1, R11.1, R12.1, R13.1, R15.1, LED1.VDD
  ;;
  ;; === SPI BUS (ESP32 → MCP4822 DAC) ===
  ;; ESP32.GPIO10 → U4./CS
  ;; ESP32.GPIO11 → U4.SDI
  ;; ESP32.GPIO12 → U4.SCK
  ;; ESP32.GPIO13 → U4./LDAC
  ;;
  ;; === DAC → OP-AMP → GALVO ===
  ;; U4.VOUTA → R5.1 → R5.2 → U5.1IN+ (non-inv input A)
  ;; U5.1OUT → R6.2 → R6.1 → U5.1IN- (feedback A)
  ;; U5.1OUT → J4.1 (Galvo X+)
  ;; J4.2 (Galvo X-) → GND
  ;;
  ;; U4.VOUTB → R7.1 → R7.2 → U5.2IN+ (non-inv input B)
  ;; U5.2OUT → R8.2 → R8.1 → U5.2IN- (feedback B)
  ;; U5.2OUT → J4.3 (Galvo Y+)
  ;; J4.4 (Galvo Y-) → GND
  ;;
  ;; === LASER TTL ===
  ;; ESP32.GPIO14 → R10.1 → R10.2 → Q1.G (gate)
  ;; Q1.S → GND
  ;; Q1.D → J3.2 (laser TTL)
  ;; R9.1 → +12V, R9.2 → Q1.D (pull-up)
  ;; J3.1 → +12V, J3.3 → GND
  ;;
  ;; === CAMERA DVP ===
  ;; ESP32.GPIO4 → J5.VSYNC
  ;; ESP32.GPIO5 → J5.HREF
  ;; ESP32.GPIO6 → J5.PCLK
  ;; ESP32.GPIO7 → J5.XCLK
  ;; ESP32.GPIO15-18 → J5.D2-D5
  ;; ESP32.GPIO8-9 → J5.D6-D7
  ;; ESP32.GPIO45-46 → J5.D8-D9
  ;; ESP32.GPIO1 → J5.SDA (+ R11 pull-up)
  ;; ESP32.GPIO2 → J5.SCL (+ R12 pull-up)
  ;; R13 → J5.RESET (pull-up to 3.3V)
  ;; R14 → J5.PWDN (pull-down to GND)
  ;;
  ;; === STATUS & SAFETY ===
  ;; ESP32.GPIO48 → LED1.DIN
  ;; ESP32.GPIO47 → SW3.1, R15.2 (pull-up)
  ;; SW3.2 → GND
  ;;
  ;; === USB (Debug/Firmware) ===
  ;; ESP32.GPIO19 → J2.D-
  ;; ESP32.GPIO20 → J2.D+
  ;; R3 (5.1K): J2.CC1 → GND
  ;; R4 (5.1K): J2.CC2 → GND
  ;;
  ;; === RESET/BOOT ===
  ;; R1 (10K): 3V3 → ESP32.EN
  ;; C9 (100nF): ESP32.EN → GND (debounce)
  ;; SW2: ESP32.EN → GND (reset button)
  ;; R2 (10K): 3V3 → ESP32.GPIO0
  ;; SW1: ESP32.GPIO0 → GND (boot button)
  ;;

