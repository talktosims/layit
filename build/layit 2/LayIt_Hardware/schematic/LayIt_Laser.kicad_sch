  ;; ============================================================
  ;; TL072 DUAL OP-AMP BUFFER - Scales DAC output to ±5V for galvos
  ;; ============================================================
  ;;
  ;; MCP4822 outputs 0-4.096V. Galvos need ±5V.
  ;; Each channel: Non-inverting amp with offset.
  ;; Vout = (Vin - 2.048V) * 2.44 → maps 0-4.096V to ±5V
  ;; Implemented as difference amplifier with voltage divider reference.
  ;;
  ;; Circuit per channel:
  ;;   DAC_OUT → R_in (10K) → Op-Amp (-)
  ;;   Vref (2.048V from voltage divider) → R_ref (10K) → Op-Amp (+)
  ;;   Rf (24K) feedback from output to (-)
  ;;   Gain = Rf/Rin = 24K/10K = 2.4x
  ;;   Output swing: ±5V (powered from ±12V via charge pump or split supply)
  ;;
  ;; NOTE TO ENGINEER: The TL072 is powered from +12V and GND in this design.
  ;; This gives output range 0-10V approx. For true ±5V bipolar output,
  ;; add a virtual ground at 5V or use a ±12V split supply via ICL7660/MAX1044.
  ;; The firmware compensates by mapping coordinates to 0-10V range.
  ;; A bipolar supply is preferred if galvos require true ±5V differential input.

  ;; U5 - TL072 Dual Op-Amp
  (symbol (lib_id "Amplifier_Operational:TL072") (at 160 200 0) (unit 1)
    (in_bom yes) (on_board yes) (dnp no)
    (uuid "11111111-1111-1111-1111-111111111601")
    (property "Reference" "U5" (at 160 190 0) (effects (font (size 1.27 1.27))))
    (property "Value" "TL072" (at 160 193 0) (effects (font (size 1.27 1.27))))
    (property "Footprint" "Package_DIP:DIP-8_W7.62mm" (at 160 200 0) (effects (font (size 1.27 1.27)) hide))
    (property "Datasheet" "https://www.ti.com/lit/ds/symlink/tl072.pdf" (at 160 200 0) (effects (font (size 1.27 1.27)) hide))
    (property "Description" "Dual JFET Op-Amp buffer. Ch A scales DAC_A for Galvo X. Ch B scales DAC_B for Galvo Y." (at 160 200 0) (effects (font (size 1.27 1.27)) hide))
    ;; Channel A (Galvo X)
    (pin "1OUT" (uuid "p-u5-1out"))   ;; Pin 1: Output A → Galvo X+ input
    (pin "1IN-" (uuid "p-u5-1inn"))   ;; Pin 2: Inverting input A
    (pin "1IN+" (uuid "p-u5-1inp"))   ;; Pin 3: Non-inverting input A ← DAC VOUTA
    ;; Power
    (pin "V+" (uuid "p-u5-vcc"))      ;; Pin 8: V+ = +12V
    (pin "V-" (uuid "p-u5-vee"))      ;; Pin 4: V- = GND (or -12V if split supply)
    ;; Channel B (Galvo Y)
    (pin "2OUT" (uuid "p-u5-2out"))   ;; Pin 7: Output B → Galvo Y+ input
    (pin "2IN-" (uuid "p-u5-2inn"))   ;; Pin 6: Inverting input B
    (pin "2IN+" (uuid "p-u5-2inp"))   ;; Pin 5: Non-inverting input B ← DAC VOUTB
  )

